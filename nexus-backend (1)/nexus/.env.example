# NEXUS — Environment Config
# cp .env.example .env  →  fill values  →  NEVER commit .env

# ── LLM (FREE) ───────────────────────────────────────────────
# Llama 3.1 70B — free at https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Google OAuth ─────────────────────────────────────────────
# credentials.json = downloaded from Google Cloud Console
# Steps: console.cloud.google.com → New Project → Enable Gmail API
#        + Calendar API → OAuth2 Desktop credentials → Download JSON
GOOGLE_CREDS_FILE=credentials.json
TOKEN_FILE=token.json
REDIRECT_URI=http://localhost:8000/auth/callback

# ── Agent behavior ────────────────────────────────────────────
BUFFER_MINUTES=10          # free space around meetings
WORK_START_HOUR=9          # no meetings before 9am
WORK_END_HOUR=18           # no meetings after 6pm
SEARCH_DAYS=7              # look ahead window
ESCALATION_THRESHOLD=70    # urgency 0-100 above this = human
EMAIL_TONE=professional
